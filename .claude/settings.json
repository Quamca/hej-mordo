{
  "permissions": {
    "allow": [
      "Read(**)",
      "Write({project}/**)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git branch*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(cd * && git *)",
      "Bash(wc -l*)",
      "Bash(grep*)",
      "Bash(find*)",
      "Bash(python*)",
      "Bash(pip*)",
      "Bash(pytest*)"
    ],
    "deny": [
      "Bash(git merge*)",
      "Bash(git checkout*)",
      "Bash(git reset*)",
      "Bash(rm -rf*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"Czy CURRENT_STATE.md jest aktualny? Jeśli nie — poproś Claude o aktualizację przed zamknięciem sesji.\"}'",
            "shell": "bash"
          }
        ]
      }
    ]
  }
}
